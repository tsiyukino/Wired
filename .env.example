# Copy this file to .env and fill in values for your environment.
# The server reads these at startup; all have defaults suitable for local dev.

# Port the HTTP/WebSocket server listens on
PORT=3000

# Absolute path to the SQLite database file.
# Required in production (NODE_ENV=production) — a relative path will cause startup failure.
DB_PATH=/var/lib/wired/wired.db

# Set to 'production' on the live server
NODE_ENV=development

# Maximum number of lobby messages kept in the database
LOBBY_MAX_HISTORY=50

# Maximum number of board threads before old ones are pruned
BOARD_MAX_THREADS=100

# Minimum milliseconds between board posts from the same IP (default: 60 seconds)
POST_COOLDOWN_MS=60000
